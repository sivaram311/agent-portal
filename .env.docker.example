PUBLIC_HOST=103.118.183.185
POSTGRES_PASSWORD=agent

CSS_ENABLED=true
# When using nginx for delena.buzz, set CSS_AUTH_URL to http://delena.buzz (proxied /auth → :9000)
CSS_AUTH_URL=https://delena.buzz
CSS_JWKS_URI=http://localhost:9000/.well-known/jwks.json
CSS_ISSUER=http://localhost:9000
APP_CORS_ORIGINS=https://delena.buzz,https://www.delena.buzz,http://delena.buzz,http://www.delena.buzz,http://103.118.183.185:4200,http://localhost:4200,http://127.0.0.1:4200

# Cursor CLI — use absolute agent.cmd path (Java cannot resolve bare "agent" without user PATH)
CURSOR_AGENT_CMD=C:\Users\Administrator\AppData\Local\cursor-agent\agent.cmd
CURSOR_API_KEY=

# Cloudflare Zone Edit token (set in real .env only — never commit secrets)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ZONE_NAME=delena.buzz
CLOUDFLARE_ACCOUNT_ID=
